# --- Секреты / окружение ---
.env
.env.local
.env.*.local

# --- Скомпилированные бинарники ---
# Бинарь модуля (go build без -o кладёт его сюда)
/vk-parser
# Сборка точки входа кладётся в bin/ (go build -o bin/parser ./app)
/bin/
# Windows / прочие платформы
*.exe
*.exe~
*.dll
*.so
*.dylib

# --- Тесты и покрытие ---
*.test
*.out
coverage.*

# --- Сгенерированные артефакты парсера (не исходники) ---
/elkidom_data.json
/*_data.json

# --- Конфиги реальных объектов (чужой контент) держим локально ---
# В репо только пример формата data/example.json.
/data/*.json
!/data/example.json

# --- Go workspace ---
go.work
go.work.sum

# --- Зависимости (если используется vendoring) ---
/vendor/

# --- IDE / ОС ---
.DS_Store
.idea/
.vscode/
